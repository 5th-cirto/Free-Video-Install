APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
DOWNLOADS_DIR=./downloads
MAX_PARALLEL_DOWNLOADS=2
REQUEST_TIMEOUT_SECONDS=120
SQLITE_DB_PATH=./data/app.db

# Auth (email/password + JWT)
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_EXPIRE_MINUTES=120
PASSWORD_BCRYPT_ROUNDS=12
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
APP_PUBLIC_BASE_URL=http://localhost:5173

# SMTP (email verification + password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Membership / quota
FREE_DAILY_AI_LIMIT=5
VIP_DURATION_DAYS=30

# AI summary (DeepSeek)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=120
# Optional explicit proxy for DeepSeek API (example: http://127.0.0.1:7890)
DEEPSEEK_PROXY_URL=

# Stripe (CNY one-time monthly VIP package)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CNY_1M=
STRIPE_SUCCESS_URL=http://localhost:5173/payment/success
STRIPE_CANCEL_URL=http://localhost:5173/payment/cancel

# Optional for platforms requiring login (e.g., some Bilibili videos)
# Use ONE of the following:
YTDLP_COOKIEFILE=
YTDLP_COOKIES_FROM_BROWSER=

# --- Frontend build (SEO) ---
# 生产站点根地址，不要尾斜杠。构建前端时 Vite 会写入 src 包内的 canonical、OG URL、og:url，
# 并生成 sitemap.xml / robots.txt（仅当此变量非空）。
# 若在 frontend 目录下执行 npm run build，可使用 frontend/.env.production（已约定正式域名为 aivideofetch.cn）
VITE_PUBLIC_SITE_URL=https://aivideofetch.cn
# 可选：Open Graph / Twitter 分享图。填写完整 https URL，或与站点根组合的站内路径（如 /og.png）。
# 需与 VITE_PUBLIC_SITE_URL 同时配置后方可写入页面。
VITE_PUBLIC_OG_IMAGE=

